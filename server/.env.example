# Server environment variables
# Copy this to .env and fill in your values — never commit .env

# ─── Required ────────────────────────────────────────────────────────────────

# Supabase project URL (from Supabase dashboard → Settings → API)
SUPABASE_URL=https://xxxx.supabase.co

# Supabase service role key — bypasses RLS; server-side only; NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Deployed frontend URL for CORS allowlist (e.g. https://my-crdt.vercel.app)
# For local dev: http://localhost:5173
ALLOWED_ORIGIN=http://localhost:5173

# ─── Optional ────────────────────────────────────────────────────────────────

# Number of operations between automatic snapshots (default: 100)
SNAPSHOT_INTERVAL=100

# HTTP/WebSocket listen port (default: 3001)
PORT=3001
