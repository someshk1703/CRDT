# Client environment variables
# Copy this to .env.local — never commit .env.local

# ─── Supabase (required) ──────────────────────────────────────────────────────

# Supabase project URL
VITE_SUPABASE_URL=https://xxxx.supabase.co

# Supabase anon/public key — safe to expose in client code (NOT the service role key)
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Server URLs (required) ───────────────────────────────────────────────────

# WebSocket server URL
# Local:       ws://localhost:3001
# Production:  wss://my-crdt.up.railway.app
VITE_WS_URL=ws://localhost:3001

# HTTP REST API base URL (same server as above, different protocol)
# Local:       http://localhost:3001
# Production:  https://my-crdt.up.railway.app
VITE_API_URL=http://localhost:3001
