{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "paths": {
      "@crdt/shared": ["../shared/src/index.ts"],
      "@crdt/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src"]
}
