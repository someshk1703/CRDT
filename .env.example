# WebSocket server environment variables
# Copy this file to server/.env and fill in values — never commit the real .env

PORT=3001

# ─── Supabase (required for Week 4+ persistence) ─────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ─── Snapshot interval ────────────────────────────────────────────────────────
# Number of operations between snapshots. Default: 100
SNAPSHOT_INTERVAL=100

# ─── Realtime broadcast (optional) ───────────────────────────────────────────
# Set to "true" to route op broadcast through Supabase Realtime postgres_changes.
# Required for multi-instance deployments.
ENABLE_REALTIME_BROADCAST=false

# Required in Week 5+ (JWT auth)
# JWT_SECRET=your-jwt-secret
